rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /sources/{allPaths=**} {
      allow read, write: if true;
    }

    match /items/{allPaths=**} {
      allow read, write: if true;
    }

    match /subscriptions/{allPaths=**} {
      allow read, write: if true;
    }

    match /digests/{allPaths=**} {
      allow read, write: if true;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
